    "    **plot_kwargs[\"instantaneous\"]\n",
    ")\n",
    "\n",
    "ax_methane.plot(\n",
    "    noise_raw_sampled.sel(ensemble=idx_ens, time=time_slice_instantaneous).time + instantaneous_offset,\n",
    "    noise_raw_sampled.sel(ensemble=idx_ens, time=time_slice_instantaneous),\n",
    "    alpha=alpha_sampled_atmospheric,\n",
    "    **plot_kwargs[\"sampled\"]\n",
    ")\n",
    "\n",
    "ax_methane.plot( # smoothed\n",
