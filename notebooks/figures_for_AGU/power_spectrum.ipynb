   "source": [
    "noise_raw_sampled = sample_ensemble_series(\n",
    "    da=noise_raw[\"ch4\"],\n",
    "    core_time=data_obs.time,\n",
    "    core_offset_flag=\"start\",\n",
    "    series_offset=150\n",
    ")\n",
    "noise_smoothed_sampled = sample_ensemble_series(\n",
    "    da=noise_smoothed[\"ch4\"],\n",
    "    core_time=data_obs.time,\n",
    "    core_offset_flag=\"start\",\n",
    "    series_offset=150\n",
    ")\n",
    "core_offset = noise_raw_sampled.time.attrs[\"core_offset\"]\n",
    "series_offset = noise_raw_sampled.time.attrs[\"series_offset\"]\n",
    "new_time = noise_raw.time + core_offset - series_offset\n",
    "noise_raw_plot = noise_raw.assign_coords(time=new_time)\n",
    "noise_smoothed_plot = noise_smoothed.assign_coords(time=new_time)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 10,
   "id": "d5f0e2cc",
   "metadata": {},
   "outputs": [],
   "source": [
    "plot_toggles = {\n",
    "    \"plot_atmospheric_ts\": True,  # plot atmospheric timeseries\n",
    "    \"plot_atmospheric_sampled_ts\": False, # plot sampled atmospheric timeseries\n",
    "    \"plot_firn_smoothed_ts\": True,  # plot firn smoothed timeseries\n",
    "    \"plot_pseudo_observations_ts\": True,  # plot pseudo observations timeseries\n",
    "}\n",
    "\n",
    "plot_kwargs = {\n",
    "    \"obs\": {\n",
    "        \"color\": \"k\",\n",
    "        \"marker\": \"o\",\n",
    "        \"linestyle\": \"None\",\n",
    "        \"markersize\": 2.5,\n",
    "    },\n",
    "    \"instantaneous\": {\"color\": colors_vibrant[\"blue\"], \"linestyle\": \"-\", \n",
    "    # \"alpha\": 0.5\n",
    "    },\n",
    "    \"smoothed\": {\n",
    "        \"color\": colors_vibrant[\"magenta\"],\n",
    "        \"linestyle\": \"-\",\n",
    "        \"linewidth\": 5,\n",
    "        # \"alpha\": 0.55,\n",
    "    },\n",
    "    \"smoothed_sampled\": {\n",
    "        \"marker\": \"o\",\n",
    "        \"linestyle\": \"None\",\n",
    "        \"markersize\": 4,\n",
    "        # \"markeredgecolor\": \"k\",\n",
    "        \"markeredgewidth\": 1,  # adjust thickness\n",
    "        # \"alpha\": 1,\n",
    "        \"color\": colors_vibrant[\"orange\"],\n",
    "    },\n",
    "    \"sampled\": {\n",
    "        \"marker\": \"o\",\n",
    "        \"linestyle\": \"None\",\n",
