    "data_obs_normalized = data_obs[\"ch4_detrended\"] * np.sqrt(1/var_obs)\n",
    "frequencies_obs, psd_obs = calculate_psd(\n",
    "    data_obs_normalized,\n",
    "    data_obs_normalized.time\n",
    ")"
   ]
