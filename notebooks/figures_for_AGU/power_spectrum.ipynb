    "# parameters\n",
    "instantaneous_offset = 165\n",
    "ppb_to_Tg = 2.75\n",
    "ylim_forcing = (-66, 66)\n",
    "yticks_forcing = [-60, -30, 0, 30, 60]\n",
    "ylim_methane = (-55, 55)\n",
    "yticks_methane = [-50, -25, 0, 25, 50]\n",
    "time_min = 800\n",
    "time_max = 1800\n",
    "xticks_ts = [800, 1000, 1200, 1400, 1600, 1800]\n",
    "idx_ens = 0\n",
    "# plot parameters\n",
    "alpha_instantaneous = 0.5\n",
    "alpha_smoothed = 0.55\n",
    "alpha_sampled_atmospheric = 0.8\n",
    "alpha_sampled_smoothed = 0.8\n",
    "markeredgecolor = \"k\"\n",
    "\n",
    "time_slice = slice(time_min, time_max)\n",
    "time_slice_instantaneous = slice(time_min - instantaneous_offset, time_max - instantaneous_offset)\n",
    "\n",
    "fig = plt.figure(figsize=(fig_width_options[\"two_column_small\"], 3))\n",
    "gs = GridSpec(\n",
    "    nrows=2,\n",
    "    ncols=1,\n",
    "    figure=fig,\n",
    "    hspace=0.1\n",
    ")\n",
    "\n",
    "# top panel is forcing\n",
    "ax_forcing = fig.add_subplot(gs[0, 0])\n",
    "ax_forcing.plot(\n",
    "    noise_raw_plot.sel(ensemble=idx_ens, time=time_slice_instantaneous).time,\n",
    "    noise_raw_plot.sel(ensemble=idx_ens, time=time_slice_instantaneous).forcing * ppb_to_Tg,\n",
    "    alpha=alpha_instantaneous,\n",
    "    **plot_kwargs[\"instantaneous\"]\n",
    ")\n",
    "ax_forcing.axhline(0, color=\"k\", linestyle=\"-.\", alpha=0.3)\n",
    "ax_forcing.set_xticks([])\n",
    "ax_forcing.set_ylim(ylim_forcing)\n",
    "ax_forcing.set_yticks(yticks_forcing)\n",
    "ax_forcing.set_ylabel(\"Source-sink imbalance\\n(Tg CH$_4$ yr$^{-1}$)\", labelpad=-1)\n",
    "\n",
    "# bottom panel is methane\n",
    "ax_methane = fig.add_subplot(gs[1, 0])\n",
    "if not plot_toggles[\"plot_atmospheric_ts\"]:\n",
